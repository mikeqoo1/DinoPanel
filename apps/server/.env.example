# DinoPanel server configuration
NODE_ENV=development
PORT=9999
HOST=127.0.0.1

# Security
JWT_SECRET=replace-with-64-hex-bytes-generated-by-install-script
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Database (SQLite path)
DATA_DIR=./data

# CORS allowed origins (comma separated). Empty = same-origin only.
CORS_ORIGINS=

# Logging
LOG_LEVEL=info

# Web static serve (path to apps/web/dist after build)
WEB_DIST=
