{
  "name": "@dinopanel/server",
  "version": "0.4.1",
  "private": true,
  "description": "DinoPanel backend (NestJS + Fastify + SQLite)",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env src/database/migrate.ts",
    "seed:admin": "tsx --env-file=.env src/seed/initial-admin.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@dinopanel/shared": "workspace:*",
    "@fastify/multipart": "^9.0.1",
    "@fastify/static": "^8.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.0.1",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.0.1",
    "acme-client": "^5",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.0.0",
    "cron-parser": "^5.5.0",
    "dockerode": "^5.0.0",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.2.0",
    "nestjs-pino": "^4.1.0",
    "nestjs-zod": "^4.3.1",
    "node-cron": "^4.2.1",
    "node-pty": "^1.0.0",
    "node-stream-zip": "^1.15.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "systeminformation": "^5.23.5",
    "tar": "^7.5.15",
    "unzipper": "^0.12.3",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/archiver": "^6.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/dockerode": "^4.0.1",
    "@types/node-cron": "^3.0.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@types/unzipper": "^0.10.11",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.30.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
