{
  "name": "dinopanel",
  "version": "0.4.6",
  "private": true,
  "description": "Modern Linux server management panel built with TypeScript + React + NestJS",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "test": "vitest run --workspace vitest.workspace.ts",
    "test:watch": "vitest --workspace vitest.workspace.ts",
    "test:e2e": "playwright test",
    "clean": "turbo run clean && rm -rf node_modules",
    "demo": "pnpm build && pnpm demo:start",
    "demo:start": "bash scripts/demo.sh start",
    "demo:stop": "bash scripts/demo.sh stop",
    "demo:restart": "bash scripts/demo.sh restart",
    "demo:status": "bash scripts/demo.sh status",
    "demo:logs": "bash scripts/demo.sh logs",
    "demo:fg": "bash scripts/demo.sh fg"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "@playwright/test": "^1.60.0",
    "vitest": "^2.1.8"
  }
}
